{
  "name": "customer-billing-app",
  "productName": "Customer Billing",
  "version": "1.0.0",
  "description": "Offline desktop billing app for customers, products, bills and WhatsApp bill sharing.",
  "main": "electron/main.js",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.10.0",
    "papaparse": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-select": "^5.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.11",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.shubhjewellery.customerbilling",
    "productName": "Customer Billing",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/db/*.db"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
